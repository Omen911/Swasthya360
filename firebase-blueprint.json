{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user demographic and Ayurvedic profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "weight": { "type": "number", "description": "Weight in kg" },
        "height": { "type": "number", "description": "Height in cm" },
        "activityLevel": { "type": "string", "enum": ["sedentary", "light", "moderate", "active", "very_active"] },
        "dosha": { "type": "string", "enum": ["Vata", "Pitta", "Kapha", "Unknown"] },
        "calorieGoal": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Favorite": {
      "title": "Favorite Remedy",
      "description": "A remedy saved by the user for quick access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "remedyId": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "remedyId", "name"]
    },
    "HealthLog": {
      "title": "Daily Health Log",
      "description": "Tracks daily calorie intake and health metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "calories": { "type": "number" },
        "foodItems": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "date", "calories"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "The user's private profile."
    },
    "/users/{userId}/favorites/{favId}": {
      "schema": "Favorite",
      "description": "Remedies favorited by the user."
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "HealthLog",
      "description": "Daily health logs for the user."
    }
  }
}
